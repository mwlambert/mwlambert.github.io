---
import { getImage } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { photos } from '../../lib/photos.js';
import { captions } from '../../data/captions.js';

// One large optimised source per photo for the gallery view.
const large = await Promise.all(
  photos.map((p) => getImage({ src: p.image, width: 1600, format: 'webp' })),
);
const slides = photos.map((p, i) => ({
  src: large[i].src,
  caption: captions[p.file] || '',
}));
---

<Base title="Travel" description="Travel photos by Michael Lambert.">
  {
    slides.length === 0 ? (
      <p class="empty">No photos yet.</p>
    ) : (
      <section class="viewer" aria-roledescription="carousel">
        <button class="v-arrow v-prev" id="vPrev" aria-label="Previous photo">
          &#8249;
        </button>
        <figure class="v-frame">
          <img id="vImg" class="v-img" src={slides[0].src} alt="" width="1600" />
          <figcaption class="v-cap" id="vCap">{slides[0].caption}</figcaption>
        </figure>
        <button class="v-arrow v-next" id="vNext" aria-label="Next photo">
          &#8250;
        </button>
        <p class="v-count"><span id="vIdx">1</span> / {slides.length}</p>
      </section>
    )
  }

  <script type="application/json" id="slides" set:html={JSON.stringify(slides)} />

  <script>
    (function () {
      const el = document.getElementById('slides');
      if (!el) return;
      const slides = JSON.parse(el.textContent || '[]');
      if (slides.length < 1) return;

      const img = document.getElementById('vImg');
      const cap = document.getElementById('vCap');
      const idxEl = document.getElementById('vIdx');
      const prev = document.getElementById('vPrev');
      const next = document.getElementById('vNext');

      // Open on the photo that was clicked in the overview (#<index>).
      let i = 0;
      const h = parseInt((location.hash || '').slice(1), 10);
      if (Number.isFinite(h) && h >= 0 && h < slides.length) i = h;

      function render() {
        img.src = slides[i].src;
        cap.textContent = slides[i].caption || '';
        idxEl.textContent = String(i + 1);
      }
      function go(step) {
        i = (i + step + slides.length) % slides.length;
        render();
      }
      render();

      prev.addEventListener('click', () => go(-1));
      next.addEventListener('click', () => go(1));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') go(-1);
        else if (e.key === 'ArrowRight') go(1);
      });

      if (slides.length < 2) {
        prev.style.display = 'none';
        next.style.display = 'none';
        document.querySelector('.v-count')?.style.setProperty('display', 'none');
      }
    })();
  </script>

  <style>
    .viewer {
      max-width: 1000px;
      margin: 24px auto 0;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      column-gap: 12px;
    }
    .v-frame {
      margin: 0;
      text-align: center;
    }
    .v-img {
      display: block;
      max-width: 100%;
      max-height: 74vh;
      width: auto;
      height: auto;
      margin: 0 auto;
      border-radius: 4px;
    }
    .v-cap {
      margin-top: 14px;
      color: var(--muted);
      font-size: 14px;
      min-height: 1em; /* reserve space so the frame doesn't jump when blank */
    }
    .v-arrow {
      background: none;
      border: 0;
      color: var(--ink);
      cursor: pointer;
      font-size: 40px;
      line-height: 1;
      padding: 8px 10px;
      opacity: 0.55;
      transition: opacity 0.15s ease;
    }
    .v-arrow:hover {
      opacity: 1;
    }
    .v-count {
      grid-column: 2;
      text-align: center;
      margin: 18px 0 0;
      color: var(--muted);
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 12px;
      letter-spacing: 0.04em;
    }

    .empty {
      color: var(--muted);
    }

    @media (max-width: 640px) {
      .viewer {
        column-gap: 4px;
      }
      .v-arrow {
        font-size: 32px;
        padding: 6px 4px;
      }
      .v-img {
        max-height: 64vh;
      }
    }
  </style>
</Base>
