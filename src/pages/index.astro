---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { experience } from '../data/experience.js';
import { education } from '../data/education.js';
import { lanes, START, END, ticks } from '../data/timeline.js';
import { getLogo, getWorkImages } from '../lib/assets.js';
// Swap src/hero.jpg for your own photo — the layout stays the same.
import hero from '../hero.jpg';

function initials(name) {
  return name
    .split(/\s+/)
    .slice(0, 2)
    .map((w) => w[0])
    .join('')
    .toUpperCase();
}

// Position helpers for the gantt (decimal year -> % across the axis).
const pct = (v) => ((v - START) / (END - START)) * 100;
const yr = (v) => Math.floor(v);
const slugify = (s) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

// One row per lane — overlapping bars are allowed to overlap (later one on top),
// rather than stacking onto a new sub-row.
const ROW = 40; // px lane height (30px bar + breathing room)
function packLane(phases) {
  return { placed: phases.map((p) => ({ ...p, row: 0 })), rows: 1 };
}

// Link the FIRST mention of each label (e.g. "CAPSTONE") inside a bullet.
// `used` is shared across a company's roles so only the first occurrence links.
const escapeHtml = (s) =>
  s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
function linkifyBullet(text, links, used) {
  let html = escapeHtml(text);
  if (!links) return html;
  for (const l of links) {
    if (used.has(l.label)) continue;
    const idx = html.indexOf(l.label);
    if (idx === -1) continue;
    used.add(l.label);
    html =
      html.slice(0, idx) +
      `<a href="${l.url}" target="_blank" rel="noopener" class="inline-link">${l.label}</a>` +
      html.slice(idx + l.label.length);
  }
  return html;
}
---

<Base description="Michael Lambert — hardware development engineer.">
  <div class="cv">
    <!-- HERO — landscape image with the intro overlaid. No name (implied by header). -->
    <section class="hero reveal">
      <!-- Swap src/hero.jpg for your own landscape photo. -->
      <Image class="hero-bg" src={hero} alt="" widths={[720, 1440]} sizes="720px" />
      <div class="hero-text">
        <p class="eyebrow">Engineer & Entrepreneur · Paris</p>
        <h1 class="headline">
          Building hardware for the next<br />generation of space exploration
        </h1>
        <ul class="stats">
          <li><b>30</b> rockets launched</li>
          <li><b>2</b> planetary missions</li>
          <li><b>2</b> startups</li>
          <li><b>10</b> years experience</li>
        </ul>
      </div>
    </section>

    <!-- LIFE TIMELINE (gantt) -->
    <section class="chart reveal" aria-label="Timeline">
      <div class="chart-inner">
        <div class="grid">
          {
            ticks.map((y, i) => (
              <span
                class="tick"
                style={`left:${pct(y)}%`}
                data-edge={i === 0 ? 'start' : i === ticks.length - 1 ? 'end' : undefined}
              >
                <i />
                <em>{'’' + String(y).slice(2)}</em>
              </span>
            ))
          }
        </div>
        {
          lanes.map((lane) => {
            const { placed, rows } = packLane(lane.phases);
            return (
            <div class="lane" style={`height:${rows * ROW}px`}>
              <span class="lane-name">{lane.name}</span>
              <div class="track">
                {placed.map((p) => {
                  const logo = getLogo(p.logo);
                  const left = pct(p.start);
                  const width = pct(Math.min(p.end, END)) - left;
                  const delay = (left / 100) * 0.5;
                  const top = p.row * ROW + 5; // centre the 30px bar in its 40px row
                  const Tag = p.href ? 'a' : 'div';
                  return (
                    <>
                    {p.labelLeft && (
                      <span
                        class="ext-label"
                        style={`right: calc(${100 - left}% + 12px); top:${top}px; --d:${delay}s`}
                      >
                        {p.label}
                      </span>
                    )}
                    <Tag
                      class={`bar ${lane.name === 'Study' ? 'study' : 'work'}`}
                      href={p.href}
                      style={`left:${left}%; width:${width}%; top:${top}px; --d:${delay}s; --bp:${p.pad ?? 3}px`}
                      title={`${p.label} · ${yr(p.start)}–${p.end >= END ? 'now' : yr(p.end)}`}
                    >
                      <div class="bar-fill" />
                      <span class="badge">
                        {logo == null ? (
                          initials(p.label)
                        ) : typeof logo === 'string' ? (
                          <img src={logo} alt={p.label} />
                        ) : (
                          <Image src={logo} alt={p.label} widths={[36, 72]} sizes="36px" />
                        )}
                      </span>
                      {width > 16 && <span class="bar-label">{p.label}</span>}
                    </Tag>
                    </>
                  );
                })}
              </div>
            </div>
            );
          })
        }
      </div>
    </section>

    <!-- EXPERIENCE TIMELINE -->
    <section class="timeline">
      <h2 class="section-title">Experience</h2>
      {
        experience.map((co) => {
          const logo = getLogo(co.logo);
          const used = new Set(); // tracks which link labels have been linked
          return (
            <article class="entry reveal" id={slugify(co.company)}>
              <div class="rail">
                <span class="dot" />
              </div>

              <div class="body">
                <header class="co">
                  <div class="logo">
                    {logo == null ? (
                      <span class="monogram">{initials(co.company)}</span>
                    ) : typeof logo === 'string' ? (
                      <img src={logo} alt={co.company} />
                    ) : (
                      <Image src={logo} alt={co.company} widths={[44, 88, 132, 176]} sizes="44px" />
                    )}
                  </div>
                  <div>
                    <h2>
                      {co.url ? (
                        <a href={co.url} target="_blank" rel="noopener">
                          {co.company}
                        </a>
                      ) : (
                        co.company
                      )}
                    </h2>
                    <span class="dur">{co.duration}</span>
                  </div>
                </header>

                {co.intro ? (
                  <p class="co-intro">{co.intro}</p>
                ) : co.intro === '' ? (
                  <p class="co-intro placeholder">[ Paragraph about your {co.company} work — to be added. ]</p>
                ) : null}

                <div class="roles">
                  {co.roles.map((role) => {
                    // photos live in src/assets/work/<company>/<role>/
                    const roleImages = getWorkImages(
                      `${slugify(co.company)}/${slugify(role.title)}`,
                    );
                    return (
                      <div class="role-item">
                        <h3>{role.title}</h3>
                        <p class="meta">
                          {role.dates}
                          {role.location && ` · ${role.location}`}
                        </p>
                        {role.bullets.length > 0 && (
                          <ul>
                            {role.bullets.map((b) => (
                              <li set:html={linkifyBullet(b, co.links, used)} />
                            ))}
                          </ul>
                        )}
                        {roleImages.length > 0 && (
                          <div class="work">
                            {roleImages.map((img) => (
                              <Image
                                src={img}
                                alt={`${co.company} — ${role.title}`}
                                widths={[300, 600]}
                                sizes="(max-width: 640px) 45vw, 220px"
                                loading="lazy"
                              />
                            ))}
                          </div>
                        )}
                      </div>
                    );
                  })}
                </div>
              </div>
            </article>
          );
        })
      }
    </section>

    <!-- EDUCATION -->
    <section class="education">
      <h2 class="section-title">Education</h2>
      {
        education.map((edu) => {
          const logo = getLogo(edu.logo);
          return (
            <article class="entry reveal" id={edu.id}>
              <div class="rail">
                <span class="dot" />
              </div>
              <div class="body">
                <header class="co">
                  <div class="logo">
                    {logo == null ? (
                      <span class="monogram">{initials(edu.school)}</span>
                    ) : typeof logo === 'string' ? (
                      <img src={logo} alt={edu.school} />
                    ) : (
                      <Image src={logo} alt={edu.school} widths={[44, 88, 132, 176]} sizes="44px" />
                    )}
                  </div>
                  <div>
                    <h2>
                      {edu.url ? (
                        <a href={edu.url} target="_blank" rel="noopener">
                          {edu.school}
                        </a>
                      ) : (
                        edu.school
                      )}
                    </h2>
                    <span class="dur">{edu.dates}</span>
                  </div>
                </header>
                <div class="roles">
                  <div class="role-item">
                    <ul>
                      <li>{edu.program}</li>
                      {(edu.bullets || []).map((b) => (
                        <li>{b}</li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </section>
  </div>

  <script>
    // Scroll-reveal: fade + rise each section as it enters view. Vanilla, tiny,
    // and disabled for anyone who prefers reduced motion.
    function initReveal() {
      const els = document.querySelectorAll('.reveal');
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach((el) => el.classList.add('in-view'));
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((en) => {
            if (en.isIntersecting) {
              en.target.classList.add('in-view');
              io.unobserve(en.target);
            }
          });
        },
        { threshold: 0.12 },
      );
      els.forEach((el) => io.observe(el));
    }
    initReveal();
  </script>

  <style>
    .cv {
      max-width: 720px;
      margin: 0 auto;
    }

    /* --- motion --- */
    .reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.in-view {
      opacity: 1;
      transform: none;
    }
    @media (prefers-reduced-motion: reduce) {
      .reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }

    /* --- hero (landscape banner with overlaid intro) --- */
    .hero {
      position: relative;
      overflow: hidden;
      border-radius: 6px;
      min-height: 400px;
      margin-bottom: 48px;
      display: flex;
      align-items: flex-end;
      isolation: isolate;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: bottom;
      z-index: 0;
    }
    /* Scrim for legibility over any photo. */
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(0, 0, 0, 0.62),
        rgba(0, 0, 0, 0.18) 55%,
        rgba(0, 0, 0, 0.05)
      );
      z-index: 1;
    }
    .hero-text {
      position: relative;
      z-index: 2;
      padding: 34px 34px 30px;
      max-width: 640px;
    }
    .eyebrow {
      font-size: 12.5px;
      font-weight: 500;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.85);
      margin: 0 0 12px;
    }
    .headline {
      font-size: 29px;
      font-weight: 400;
      line-height: 1.25;
      color: #fff;
      margin: 0 0 20px;
      max-width: 560px; /* drives the even two-line wrap */
    }
    .stats {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 6px 20px;
      font-size: 14px;
      color: rgba(255, 255, 255, 0.92);
    }
    .stats li {
      white-space: nowrap;
    }
    .stats b {
      font-weight: 600;
      color: #fff;
    }
    .links {
      display: flex;
      gap: 18px;
      margin-top: 24px;
      font-size: 13px;
    }
    .links a {
      color: var(--muted);
      border-bottom: 1px solid transparent;
      transition: color 0.15s ease, border-color 0.15s ease;
    }
    .links a:hover {
      color: var(--ink);
      border-color: var(--ink);
    }

    .placeholder {
      color: #b3b3b3;
      font-style: italic;
    }

    /* --- life timeline (gantt) --- */
    .chart {
      margin: 4px 0 52px;
    }

    /* Breakout: hero + gantt run wider than the 720px reading column.
       Uses `translate` (not `transform`) so it doesn't fight the reveal
       animation, which animates `transform`. */
    .hero,
    .chart {
      /* 1156px = the nav/page frame (1200px max-width − 44px padding), so the
         hero + gantt edges line up with the header. Drop to ~960px for a
         narrower feel. */
      width: min(1156px, calc(100vw - 44px));
      margin-left: 50%;
      translate: -50% 0;
    }

    .chart-inner {
      position: relative;
      padding-bottom: 40px;
    }
    .grid {
      position: absolute;
      left: 62px;
      right: 0;
      top: 0;
      bottom: 40px;
      pointer-events: none;
    }
    .tick {
      position: absolute;
      top: 0;
      bottom: 0;
    }
    .tick i {
      position: absolute;
      top: 0;
      bottom: 0;
      left: 0;
      width: 1px;
      background: #e4e4e4;
    }
    .tick em {
      position: absolute;
      left: 0;
      bottom: -30px;
      transform: translateX(-50%);
      font-size: 11px;
      font-style: normal;
      color: #9a9a9a;
      white-space: nowrap;
    }
    .tick[data-edge='start'] em {
      transform: none;
    }
    .tick[data-edge='end'] em {
      transform: translateX(-100%);
    }

    .lane {
      display: grid;
      grid-template-columns: 62px 1fr;
      align-items: center;
      /* height is set inline per lane = (sub-rows × ROW) */
    }
    .lane-name {
      font-size: 12px;
      color: var(--muted);
    }
    .track {
      position: relative;
      height: 100%;
    }

    .bar {
      position: absolute;
      height: 30px;
      min-width: 30px;
      overflow: hidden;
      border-radius: 6px;
    }
    a.bar {
      cursor: pointer;
    }
    a.bar:hover .bar-fill {
      filter: brightness(1.12);
    }
    a.bar:hover .badge {
      box-shadow: 0 0 0 1px #bdbdbd;
    }
    .bar-fill {
      position: absolute;
      inset: 0;
      border-radius: 6px;
      transform-origin: left center;
      transform: scaleX(0);
      transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
      transition-delay: var(--d);
    }
    .chart.in-view .bar-fill {
      transform: scaleX(1);
    }
    .bar.work .bar-fill {
      background: #7f7f7f;
    }
    .bar.study .bar-fill {
      background: #dcdcdc;
    }

    .badge {
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 30px;
      height: 30px;
      border-radius: 6px;
      background: #fff;
      box-shadow: 0 0 0 1px #e0e0e0;
      box-sizing: border-box;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 600;
      color: #777;
      overflow: hidden;
      z-index: 2;
      opacity: 0;
      transition: opacity 0.4s ease;
      transition-delay: var(--d);
    }
    .chart.in-view .badge {
      opacity: 1;
    }
    .badge :global(img) {
      /* Fit fully inside the badge — cannot overflow, so it never gets clipped. */
      max-width: 100%;
      max-height: 100%;
      width: auto;
      height: auto;
      object-fit: contain;
    }

    .bar-label {
      position: absolute;
      left: 38px;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      font-size: 12px;
      z-index: 2;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.4s ease;
      transition-delay: var(--d);
    }
    .chart.in-view .bar-label {
      opacity: 1;
    }
    .bar.work .bar-label {
      color: #fff;
    }
    .bar.study .bar-label {
      color: #555;
    }

    /* label placed to the LEFT of a lone bar (outside its clipping) */
    .ext-label {
      position: absolute;
      height: 30px;
      display: flex;
      align-items: center;
      white-space: nowrap;
      font-size: 12px;
      color: var(--ink);
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.4s ease;
      transition-delay: var(--d);
    }
    .chart.in-view .ext-label {
      opacity: 1;
    }

    @media (prefers-reduced-motion: reduce) {
      .bar-fill {
        transform: scaleX(1);
        transition: none;
      }
      .badge,
      .bar-label,
      .ext-label {
        opacity: 1;
        transition: none;
      }
    }

    @media (max-width: 640px) {
      .bar-label,
      .ext-label {
        display: none;
      }
      /* A 14-year horizontal gantt can't read at phone width — hide it;
         the Experience list below carries the same information. */
      .chart {
        display: none;
      }
    }

    /* --- section headings --- */
    .section-title {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: var(--muted);
      font-weight: 500;
      margin: 0 0 22px;
    }

    /* --- education (reuses the .entry timeline layout) --- */
    .education {
      margin-top: 44px;
    }

    /* jump-link scroll offsets */
    .entry {
      scroll-margin-top: 28px;
    }

    /* --- timeline --- */
    .entry {
      display: grid;
      grid-template-columns: 24px 1fr;
      gap: 20px;
      padding-bottom: 46px;
    }
    .rail {
      position: relative;
    }
    .rail::before {
      content: '';
      position: absolute;
      left: 5px;
      top: 6px;
      bottom: -46px;
      width: 1px;
      background: #e6e6e6;
    }
    .entry:last-child .rail::before {
      display: none;
    }
    .dot {
      position: absolute;
      left: 0;
      top: 4px;
      width: 11px;
      height: 11px;
      border-radius: 50%;
      background: var(--ink);
    }

    .co {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .logo {
      width: 44px;
      height: 44px;
      flex: 0 0 44px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .logo :global(img) {
      width: 100%;
      height: 100%;
      object-fit: contain;
      border-radius: 6px;
    }
    .monogram {
      font-size: 15px;
      font-weight: 500;
      color: #9a9a9a;
      letter-spacing: 0.03em;
    }

    .co h2 {
      font-size: 17px;
      font-weight: 500;
      margin: 0;
    }
    .co h2 a {
      border-bottom: 1px solid transparent;
      transition: border-color 0.15s ease;
    }
    .co h2 a:hover {
      border-color: var(--ink);
    }
    .dur {
      font-size: 12.5px;
      color: var(--muted);
    }

    .co-intro {
      margin: 12px 0 0 58px;
      font-size: 14.5px;
      line-height: 1.7;
    }

    .roles {
      margin: 16px 0 0 58px;
    }
    /* inline project / mission links inside bullets */
    .role-item :global(.inline-link) {
      color: inherit;
      text-decoration: none;
      border-bottom: 1px solid #bbb;
      transition: border-color 0.15s ease;
    }
    .role-item :global(.inline-link:hover) {
      border-color: var(--ink);
    }
    .role-item {
      margin-bottom: 20px;
    }
    .role-item:last-child {
      margin-bottom: 0;
    }
    .role-item h3 {
      font-size: 15px;
      font-weight: 500;
      margin: 0 0 2px;
    }
    .meta {
      font-size: 12.5px;
      color: var(--muted);
      margin: 0 0 8px;
    }
    .role-item ul {
      margin: 0;
      padding-left: 18px;
    }
    .role-item li {
      font-size: 14px;
      line-height: 1.6;
      color: #333;
      margin-bottom: 5px;
    }

    .work {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 10px;
      margin: 12px 0 4px;
    }
    .work :global(img) {
      width: 100%;
      height: 120px;
      object-fit: cover;
      border-radius: 4px;
    }

    @media (max-width: 640px) {
      .co-intro,
      .roles,
      .work {
        margin-left: 0;
      }
      .work {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
</Base>
