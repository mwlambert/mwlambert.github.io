---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
// Swap src/about.jpg for your own portrait — the layout stays the same.
import portrait from '../about.jpg';
---

<Base title="About">
  <div class="about">
    <div class="text">
      <p>
        Ko te pae tawhiti, whāia kia tata.<br />
        Ko te pae tata whakamaua kia tina.
      </p>
      <p>
        <a href="mailto:michael@lambertspace.com">michael@lambertspace.com</a>
      </p>

      {/* --- Draft bio, parked for now. Restore when ready (add the pepeha
             above it as the opener). --------------------------------------
      <p>
        I grew up in Hawke's Bay, on the East Coast of Aotearoa, with roots in
        Wairoa. It's a quiet part of the world — and, as it happens, one of the
        only places on earth you can watch an orbital rocket lift off.
      </p>
      <p>
        I was drawn to Rocket Lab by the sheer challenge of it — an entire
        industry taking root in New Zealand for the first time. Its launch site
        sits on the Māhia Peninsula, just up the coast from where my people are
        from; the hardware I helped build flies from the same shoreline. That
        pull toward hard problems took me deeper into launch and space, and
        eventually across the world to Europe, to keep exploring and building.
      </p>
      <p>
        Today I'm based in Paris, developing hardware across climate and space —
        and building a few things of my own on the side.
      </p>
      ------------------------------------------------------------------- */}
    </div>
    <Image
      class="portrait"
      src={portrait}
      alt="Michael Lambert"
      widths={[320, 640]}
      sizes="(max-width: 640px) 100vw, 320px"
    />
  </div>

  <style>
    .about {
      display: flex;
      gap: 40px;
      align-items: flex-start;
      justify-content: space-between;
      width: 100%;
    }
    .portrait {
      width: 320px;
      flex: 0 0 320px;
      height: auto;
    }
    .text {
      max-width: 420px;
      font-size: 16px;
      line-height: 1.7;
      padding-top: 4px;
    }
    .text a {
      border-bottom: 1px solid currentColor;
    }

    @media (max-width: 640px) {
      .about {
        flex-direction: column;
        gap: 24px;
      }
      .portrait {
        width: 100%;
        flex: none;
      }
    }
  </style>
</Base>
