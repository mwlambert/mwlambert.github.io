---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { photos } from '../lib/photos.js';
---

<Base title="Photography" description="Photography by Michael Lambert.">
  {
    photos.length === 0 ? (
      <p class="empty">
        No photos yet. Drop images into <code>src/photos/</code> and they'll appear
        here, newest first.
      </p>
    ) : (
      <div class="gallery">
        {photos.map((p) => (
          <Image
            src={p.image}
            alt=""
            widths={[600, 900, 1400]}
            sizes="(max-width: 700px) 100vw, 580px"
            loading="lazy"
          />
        ))}
      </div>
    )
  }

  <style>
    /* Sparse, loosely-placed masonry — generous whitespace and a staggered
       rhythm so it reads as hand-arranged rather than a tight uniform grid. */
    .gallery {
      columns: 2;
      column-gap: 176px;
      max-width: 982px;
      margin: 32px auto 0;
    }

    @media (max-width: 640px) {
      .gallery {
        columns: 1;
        column-gap: 0;
      }
    }

    .gallery :global(img) {
      break-inside: avoid;
      margin-bottom: 80px;
      transition: opacity 0.2s ease;
    }

    /* Irregular vertical gaps (overlapping multiples ≈ pseudo-random). */
    .gallery :global(img:nth-child(3n)) {
      margin-bottom: 152px;
    }
    .gallery :global(img:nth-child(4n)) {
      margin-bottom: 112px;
    }
    .gallery :global(img:nth-child(7n)) {
      margin-bottom: 188px;
    }

    /* Occasional narrower frames, alternately nudged left/right, for a
       sparser off-grid feel. */
    .gallery :global(img:nth-child(5n)) {
      width: 74%;
    }
    .gallery :global(img:nth-child(6n)) {
      width: 86%;
      margin-left: auto;
    }
    .gallery :global(img:nth-child(8n)) {
      width: 64%;
    }

    @media (max-width: 640px) {
      /* Keep phones simple: full width, gentle uniform spacing. */
      .gallery :global(img),
      .gallery :global(img:nth-child(3n)),
      .gallery :global(img:nth-child(4n)),
      .gallery :global(img:nth-child(7n)) {
        width: 100%;
        margin-left: 0;
        margin-bottom: 64px;
      }
      .gallery :global(img:nth-child(5n)),
      .gallery :global(img:nth-child(6n)),
      .gallery :global(img:nth-child(8n)) {
        width: 100%;
        margin-left: 0;
      }
    }

    .gallery :global(img:hover) {
      opacity: 0.9;
    }

    .empty {
      color: var(--muted);
    }

    code {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 12px;
    }
  </style>
</Base>
