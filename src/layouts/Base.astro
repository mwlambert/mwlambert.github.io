---
const { title, description } = Astro.props;
const siteTitle = 'Michael Lambert';
const pageTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const desc =
  description ||
  'Michael Lambert — engineer & entrepreneur. Hardware development across space, launch, and climate.';
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
// The homepage nav sits over the dark hero image, so it always needs light text.
const isHome = Astro.url.pathname === '/';
// Which top-level section we're in — used to highlight the active nav link.
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href);
// Copyright year — resolves at build time (the site rebuilds on every deploy).
const year = new Date().getFullYear();
// Back-to-top only helps on the long, scrollable pages — skip it on About.
const showTop = Astro.url.pathname !== '/about/';
const ogImage = Astro.site ? new URL('/og.jpg', Astro.site).href : '/og.jpg';

// Edit these lines to change your contact links everywhere.
const instagram = 'https://www.instagram.com/creampaua/';
const linkedin = 'https://www.linkedin.com/in/michaelp78';
const email = 'michael@lambertspace.com';
---

<!doctype html>
<html lang="en" data-theme={isHome ? 'dark' : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Mark JS available before body paints, so progressive-enhancement
         styles (e.g. fade-in photos) never leave content hidden without JS. -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Social preview (Open Graph + Twitter) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <span id="top"></span>
    <header class:list={['site-header', { home: isHome }]}>
      <a class="brand" href="/">{siteTitle}</a>
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="nav">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      <nav class="nav" id="nav">
        <a href="/projects/" aria-current={isActive('/projects/') ? 'page' : undefined}>Projects</a>
        <a href="/photography/" aria-current={isActive('/photography/') ? 'page' : undefined}>Photography</a>
        <a href="/about/" aria-current={isActive('/about/') ? 'page' : undefined}>About</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span class="foot-copy">© {year} {siteTitle}</span>
      {showTop && <a href="#top" class="foot-top">Back to top ↑</a>}
      <span class="foot-social">
        <a href={linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"></path>
          </svg>
        </a>
        <a href={instagram} target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href={`mailto:${email}`} aria-label="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2.5" y="5" width="19" height="14" rx="2"></rect>
            <path d="M3 6.5l9 6 9-6"></path>
          </svg>
        </a>
      </span>
    </footer>

    <style is:global>
      :root {
        /* ===== Light theme (default) ===== */
        --ink: #141414;
        --muted: #8a8a8a;
        --bg: #ffffff;
        --line: rgba(0, 0, 0, 0.1);
        --bullet: #333333;
        --link-underline: #bbbbbb;
        /* gantt */
        --panel: transparent;
        --panel-border: transparent;
        --grid: #e4e4e4;
        --tick: #9a9a9a;
        --work-bar: linear-gradient(180deg, #cfcfcf, #c2c2c2);
        --study-bar: linear-gradient(180deg, #e8e8e8, #dedede);
        --work-label: #333333;
        --study-label: #666666;
        --bar-sheen: rgba(255, 255, 255, 0.45);
        /* hero-bottom fade: transparent in light (stays a contained banner) */
        --hero-fade: transparent;

        --maxw: 1200px;
        --gap: 14px;
        --font: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      }
      html[data-theme='dark'] {
        /* ===== Dark theme ===== */
        --ink: #eceef2;
        --muted: #85878f;
        --bg: #0a0b0e;
        --line: rgba(255, 255, 255, 0.1);
        --bullet: #c3c5cd;
        --link-underline: rgba(255, 255, 255, 0.32);
        --panel: radial-gradient(120% 140% at 70% 0%, #14151b 0%, #0a0b0f 60%, #070709 100%);
        --panel-border: #1e1f27;
        --grid: rgba(255, 255, 255, 0.06);
        --tick: #63646f;
        --work-bar: rgba(255, 255, 255, 0.03);
        --study-bar: rgba(255, 255, 255, 0.015);
        --work-label: #dbdde3;
        --study-label: #c1c3cb;
        --bar-sheen: transparent;
        --bar-border: 1px solid rgba(255, 255, 255, 0.26);
        /* hero dissolves into the dark page */
        --hero-fade: var(--bg);
      }

      * {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
        scroll-behavior: smooth;
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--font);
        font-size: 15px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        /* sticky footer: fill at least the viewport so short pages push the
           footer to the bottom rather than floating it mid-screen */
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .site-header {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 20;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 26px 22px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .brand {
        font-size: 24px;
        font-weight: 400;
        letter-spacing: 0.01em;
      }

      .nav {
        display: flex;
        align-items: center;
        gap: 20px;
        font-size: 14px;
      }

      .nav a {
        color: var(--muted);
        transition: color 0.15s ease;
        display: inline-flex;
        align-items: center;
      }

      .nav a:hover {
        color: var(--ink);
      }

      /* Current page — brighter, with a subtle underline. (The homepage isn't
         in the nav, so an active link only ever appears on the light pages.) */
      .nav a[aria-current='page'] {
        color: var(--ink);
        text-decoration: underline;
        text-underline-offset: 5px;
        text-decoration-thickness: 1.5px;
        text-decoration-color: var(--line);
      }

      .nav-toggle {
        display: none;
        background: none;
        border: 0;
        padding: 4px;
        margin: -4px;
        color: var(--ink);
        cursor: pointer;
      }

      /* On the homepage the nav overlays the dark hero photo, so force light
         nav colours there (desktop only — on mobile the nav is a solid
         dropdown panel that follows the page). */
      @media (min-width: 641px) {
        .site-header.home .brand {
          color: #fff;
        }
        .site-header.home .nav a {
          color: rgba(255, 255, 255, 0.82);
        }
        .site-header.home .nav a:hover {
          color: #fff;
        }
      }

      /* --- mobile nav: collapse into a dropdown menu --- */
      @media (max-width: 640px) {
        /* Keep the header absolute (overlaying the hero) like desktop, so the
           homepage hero runs behind the nav on phones too. Absolute also keeps
           it out of the body flex-column, so brand + hamburger stay
           edge-aligned rather than centring together. The dropdown menu still
           anchors to it (it's a positioned ancestor). */
        .nav-toggle {
          display: inline-flex;
        }
        .nav {
          display: none;
          position: absolute;
          top: 100%;
          right: 22px;
          z-index: 30;
          flex-direction: column;
          align-items: flex-start;
          gap: 18px;
          background: var(--bg);
          padding: 20px 26px;
          border: 1px solid var(--line);
          border-radius: 12px;
          box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
          font-size: 16px;
        }
        .nav.open {
          display: flex;
        }
      }

      main {
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        /* grow to absorb slack so the footer sticks to the bottom */
        flex: 1 0 auto;
        /* top padding clears the overlaid nav on inner pages; the homepage
           hero cancels it with a matching negative margin to run behind the nav */
        padding: 88px 22px 60px;
      }

      .site-footer {
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 40px 22px;
        color: var(--muted);
        font-size: 13px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 16px;
      }
      .foot-copy {
        grid-column: 1;
        justify-self: start;
      }
      .foot-top {
        grid-column: 2;
        justify-self: center;
      }
      .foot-social {
        grid-column: 3;
        justify-self: end;
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .foot-social a,
      .foot-top {
        color: var(--muted);
        transition: color 0.15s ease;
      }
      .foot-social a {
        display: inline-flex;
      }
      .foot-social a:hover,
      .foot-top:hover {
        color: var(--ink);
      }
      @media (max-width: 520px) {
        .site-footer {
          grid-template-columns: 1fr;
          justify-items: center;
          gap: 14px;
          text-align: center;
        }
        .foot-copy,
        .foot-top,
        .foot-social {
          grid-column: 1;
          justify-self: center;
        }
      }

      img {
        display: block;
        width: 100%;
        height: auto;
      }
    </style>

    <script>
      // Mobile nav dropdown toggle.
      function initNav() {
        const toggle = document.querySelector('.nav-toggle');
        const nav = document.getElementById('nav');
        if (!toggle || !nav) return;
        const setOpen = (open) => {
          nav.classList.toggle('open', open);
          toggle.setAttribute('aria-expanded', String(open));
        };
        toggle.addEventListener('click', () => setOpen(!nav.classList.contains('open')));
        nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
        document.addEventListener('click', (e) => {
          if (!nav.classList.contains('open')) return;
          if (nav.contains(e.target) || toggle.contains(e.target)) return;
          setOpen(false);
        });
      }
      initNav();
    </script>
  </body>
</html>
